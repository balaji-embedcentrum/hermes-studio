# Sylang Studio — Environment Variables
#
# Copy this to .env and fill in the values:
#   cp .env.example .env
#
# SECURITY: .env is gitignored. Never commit this file with real values.
# All `process.env.*` keys live here; only `VITE_*` keys are exposed to
# the browser bundle (everything else is server-side only).

# ═══════════════════════════════════════════════════════════════
# REQUIRED — Supabase (auth, DB, realtime)
# Get these from https://supabase.com → Your Project → Settings → API
# ═══════════════════════════════════════════════════════════════

# Public — safe to expose in client bundle
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...

# SERVER-ONLY — bypasses Row-Level Security; never ship to browser
SUPABASE_SERVICE_KEY=eyJ...

# SERVER-ONLY — encrypts secrets at rest (agent api_key, github_token).
# Generate: openssl rand -base64 32   (must decode to exactly 32 bytes)
# REQUIRED in production. Losing it makes encrypted secrets unrecoverable —
# keep an offline backup. Never commit. See deploy/KEY-MANAGEMENT.md.
SECRETS_ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════
# REQUIRED — Agent gateway
# The OpenAI-compatible Python backend (Hermes agent, LiteLLM, etc.)
# ═══════════════════════════════════════════════════════════════

# Public URL of your agent gateway. For split-tier deployments this
# points at your OVH (or other) box; for single-box deploys use
# http://hermes-agent:8642 (Docker internal) or http://127.0.0.1:8642.
HERMES_API_URL=https://agent.hermes-studio.com

# Bearer token authenticating web → agent requests.
# Generate with: openssl rand -hex 32
# Must match the token configured on the agent gateway.
HERMES_API_TOKEN=

# ═══════════════════════════════════════════════════════════════
# REQUIRED — Anthropic (if the agent uses Claude)
# Get your key at https://console.anthropic.com/settings/keys
# ═══════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════════════════
# OPTIONAL — Workspace storage
# ═══════════════════════════════════════════════════════════════

# Where per-user GitHub clones live. In the production docker-compose,
# /opt/hermes/workspace on the host is mounted here. Leave as default
# for local dev.
HERMES_WORKSPACE_DIR=/workspace

# Per-agent workspace root inside the agent container. Used by the
# send-stream route when computing the absolute path the agent should
# operate on. Default: /opt/workspaces.
# HERMES_AGENT_WORKSPACE_ROOT=/opt/workspaces

# Hermes home dir — holds skills/, memories/, knowledge/, runs/, etc.
# Default: ~/.hermes
# HERMES_HOME=/Users/you/.hermes

# Override the runs log dir (defaults to $TMPDIR/hermes-runs).
# HERMES_RUNS_DIR=/var/log/hermes-runs

# Override the knowledge browser source dir (defaults to ~/.hermes/knowledge).
# KNOWLEDGE_DIR=/Users/you/Documents/knowledge

# ═══════════════════════════════════════════════════════════════
# OPTIONAL — Local hermes-agent (sibling repo auto-start in dev)
# ═══════════════════════════════════════════════════════════════

# Absolute path to a local hermes-agent checkout. If unset, vite.config.ts
# looks for ../hermes-agent next to this repo. Set only if you keep
# hermes-agent somewhere else.
# HERMES_AGENT_PATH=/Users/you/Documents/hermes-agent

# Default LLM model the agent reports for /v1/models. Falls back to
# whatever the gateway returns if unset.
# HERMES_DEFAULT_MODEL=claude-3-5-sonnet-latest

# Override the agent URL map (server-side only). JSON object mapping
# container_name → internal URL. Used in production with multiple agents.
# AGENT_URLS={"agent-1":"http://agent-1:8642","agent-2":"http://agent-2:8642"}

# ═══════════════════════════════════════════════════════════════
# OPTIONAL — Tailscale / LAN access in dev
# ═══════════════════════════════════════════════════════════════

# Comma-separated hostnames allowed to hit the Vite dev server.
# Production deploy doesn't use the dev server, so leave blank in prod.
# HERMES_ALLOWED_HOSTS=my-server.tail1234.ts.net

# ═══════════════════════════════════════════════════════════════
# OPTIONAL — Browser telemetry ping (active-users.ts)
# ═══════════════════════════════════════════════════════════════
# These two are VITE_* prefixed because they're read in the browser
# bundle via `import.meta.env.VITE_*`. Server-only env vars must NOT
# carry the VITE_ prefix.

# Endpoint that receives a 1-per-day fingerprinted ping per active user.
# Leave unset to disable telemetry entirely (the ping silently no-ops).
# VITE_PING_URL=https://telemetry.example.com/ping

# Reported in the ping payload's `version` field. Falls back to "1.0.0".
# VITE_APP_VERSION=0.1.0
